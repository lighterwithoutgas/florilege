rules_version = '2';

// Keepsake Book — multi-tenant Firestore rules
//
// Roles:
//  • Friends   → anonymous auth; may CREATE a message under a book.
//  • Recipient → custom token {bookId, role:'viewer'}    (from redeemKey)
//  • Caretaker → custom token {bookId, role:'caretaker'} (optional)
//  • Owner     → the signed-in creator (books/{id}.ownerUid)
// Deletes and file removal happen via the deletePage Cloud Function.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function claimFor(bookId) {
      return request.auth.token.bookId == bookId;
    }
    function isViewer(bookId) {
      return signedIn() && claimFor(bookId) &&
             (request.auth.token.role == 'viewer' || request.auth.token.role == 'caretaker');
    }
    function isOwner(bookId) {
      return signedIn() &&
             request.auth.uid == get(/databases/$(database)/documents/books/$(bookId)).data.ownerUid;
    }
    function bookIsActive(bookId) {
      return exists(/databases/$(database)/documents/books/$(bookId)) &&
             get(/databases/$(database)/documents/books/$(bookId)).data.status == 'active';
    }

    // pending checkouts: a server-only holding area for a book's docs between
    // "Pay" and a confirmed Stripe payment. Holds hashed keys + private content,
    // so no client may ever read or write it (the Admin SDK in Functions bypasses
    // these rules). The stripeWebhook deletes the doc once the book is created.
    match /checkouts/{bookId} {
      allow read, write: if false;
    }

    match /books/{bookId} {
      // public theme doc: any signed-in user (incl. anonymous friends) may read,
      // so the submission page can render the right flower/name.
      allow get: if signedIn();
      // listing is owner-only: the "My books" dashboard queries
      // books where ownerUid == the signed-in user, and the rule is
      // checked per returned document, so a query without that filter
      // is rejected. Strangers can never enumerate other people's books.
      allow list: if signedIn() && resource.data.ownerUid == request.auth.uid;
      // books are created only by the startCheckout Cloud Function (Admin SDK).
      allow create: if false;
      allow update: if isOwner(bookId);
      allow delete: if isOwner(bookId);

      // private recipient-facing content (dedication, closing, then-photo):
      // only the recipient/caretaker/owner — never the contributing friends.
      match /private/content {
        allow get: if isViewer(bookId) || isOwner(bookId);
        allow write: if isOwner(bookId);
      }
      // hashed keys: no client may ever read or write these (Functions only).
      match /private/keys {
        allow read, write: if false;
      }

      // friends' pages
      match /messages/{msgId} {
        allow create: if signedIn()
          && bookIsActive(bookId)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 80
          && request.resource.data.message is string
          && request.resource.data.message.size() <= 2000;
        allow read: if isViewer(bookId) || isOwner(bookId);
        allow update: if false;
        // deletion goes through the deletePage Cloud Function (so files go too)
        allow delete: if false;
      }
    }
  }
}
