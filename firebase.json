{
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "graphify-out/**",
      "README.md",
      "*.rules"
    ],
    "rewrites": [
      { "source": "/a/**", "destination": "/add.html" },
      { "source": "/b/**", "destination": "/book.html" },
      { "source": "/m/**", "destination": "/admin.html" },
      { "source": "/s/**", "destination": "/success.html" },
      { "source": "/my", "destination": "/my.html" }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
