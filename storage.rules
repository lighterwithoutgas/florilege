rules_version = '2';

// Keepsake Book — multi-tenant Storage rules
//
// Friends upload into their own folder under a book and may read only
// their own files (for the live preview). Recipient/owner never read
// Storage directly — they display images via the download URLs stored
// in the (private) message docs. File deletion happens in the
// deletePage Cloud Function via the Admin SDK.

service firebase.storage {
  match /b/{bucket}/o {

    // recipient "then & now" photos, uploaded before the book exists:
    // uploads/{uid}/{file}. The buyer (anonymous) uploads to their own folder;
    // the real reference is the download URL saved into the book's private content.
    match /uploads/{uid}/{file} {
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow read: if request.auth != null;
      allow delete, update: if false;
    }

    // friend submissions: books/{bookId}/submissions/{uid}/{file}
    match /books/{bookId}/submissions/{uid}/{file} {
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 25 * 1024 * 1024;
      allow read: if request.auth != null && request.auth.uid == uid;
      allow delete, update: if false;
    }

    // owner-uploaded "then" photo: books/{bookId}/owner/{uid}/{file}
    // Only that signed-in user can write their own folder; the real
    // reference is the URL the owner saves into private content.
    match /books/{bookId}/owner/{uid}/{file} {
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 25 * 1024 * 1024;
      allow read: if request.auth != null;
      allow delete: if false;
    }
  }
}
